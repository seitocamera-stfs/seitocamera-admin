# ===========================================
# Admin — Variables d'Entorn
# ===========================================

# Empresa
COMPANY_NAME=Seito Camera
COMPANY_LEGAL_NAME=Seito Camera S.L.
COMPANY_NIF=B09805995
COMPANY_SECTOR=lloguer d'equips audiovisuals i fotografia
COMPANY_CITY=Barcelona
# Nom que apareix als moviments bancaris propis (per excloure de conciliació)
COMPANY_BANK_NAME=SEITO CAMERA

# Servidor
NODE_ENV=development
PORT=4000

# Base de dades PostgreSQL
DATABASE_URL=postgresql://seitocamera:seitocamera_dev_2024@localhost:5432/seitocamera_admin

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT — IMPORTANT: Usa secrets llargs i diferents per cada un!
# Genera'ls amb: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=canvia-aquest-secret-en-produccio
JWT_REFRESH_SECRET=canvia-aquest-altre-secret-diferent
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (per CORS)
FRONTEND_URL=http://localhost:5173

# Google Drive
# Opció 1: Service Account (recomanat per producció)
GOOGLE_SERVICE_ACCOUNT_KEY=./google-service-account.json
# Opció 2: Credencials JSON inline (per Docker)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
# Opció 3: OAuth2 (per desenvolupament)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
GDRIVE_ROOT_FOLDER=SeitoCamera

# Rentman
RENTMAN_API_URL=https://api.rentman.net
RENTMAN_API_TOKEN=

# Zoho Mail
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ACCOUNT_ID=
# Multi-compte: separar Account IDs per coma (descobrir-los amb: node scripts/zoho-list-accounts.js)
# ZOHO_ACCOUNT_IDS=123456,789012,345678

# Claude API (agent comptable + extracció d'equips + extracció factures PDF)
ANTHROPIC_API_KEY=
# Model per extracció de factures (per defecte: claude-haiku-4-5-20251001, més ràpid i barat)
# CLAUDE_EXTRACT_MODEL=claude-haiku-4-5-20251001

# Logging
LOG_LEVEL=info
