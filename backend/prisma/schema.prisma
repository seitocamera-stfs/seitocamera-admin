// ===========================================
// SeitoCamera Admin — Schema Prisma
// ===========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
// Usuaris i Autenticació
// ===========================================

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String
  role          Role     @default(VIEWER)
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relacions
  notes             Note[]
  reminders         Reminder[]
  reminderMentions  ReminderMention[]
  activityLogs      ActivityLog[]

  @@map("users")
}

// ===========================================
// Proveïdors i Clients
// ===========================================

model Supplier {
  id          String   @id @default(cuid())
  name        String
  nif         String?  @unique
  email       String?
  phone       String?
  address     String?
  city        String?
  postalCode  String?
  country     String   @default("ES")
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacions
  receivedInvoices  ReceivedInvoice[]

  @@map("suppliers")
}

model Client {
  id          String   @id @default(cuid())
  name        String
  nif         String?  @unique
  email       String?
  phone       String?
  address     String?
  city        String?
  postalCode  String?
  country     String   @default("ES")
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacions
  issuedInvoices  IssuedInvoice[]

  @@map("clients")
}

// ===========================================
// Factures Rebudes (de proveïdors)
// ===========================================

enum InvoiceStatus {
  PENDING
  PDF_PENDING
  REVIEWED
  APPROVED
  REJECTED
  PAID
  PARTIALLY_PAID
}

enum InvoiceSource {
  MANUAL          // Creada manualment des del panell
  EMAIL_WITH_PDF  // Via Zoho Mail amb PDF adjunt
  EMAIL_NO_PDF    // Via Zoho Mail sense PDF (notificació)
  GDRIVE_SYNC     // Pujada manualment a Google Drive i sincronitzada
  BANK_DETECTED   // Detectada a partir d'un moviment bancari
}

model ReceivedInvoice {
  id                String        @id @default(cuid())
  invoiceNumber     String
  supplierId        String?
  issueDate         DateTime
  dueDate           DateTime?
  subtotal          Decimal       @db.Decimal(12, 2)
  taxRate           Decimal       @default(21) @db.Decimal(5, 2)
  taxAmount         Decimal       @db.Decimal(12, 2)
  totalAmount       Decimal       @db.Decimal(12, 2)
  currency          String        @default("EUR")
  status            InvoiceStatus @default(PENDING)
  source            InvoiceSource @default(MANUAL)
  category          String?
  description       String?
  ocrRawData        Json?
  ocrConfidence     Float?
  originalFileName  String?
  filePath          String?
  gdriveFileId      String?       // ID del fitxer a Google Drive
  emailMessageId    String?
  isDuplicate       Boolean       @default(false)
  duplicateOfId     String?       // ID de la factura original si és duplicat
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relacions
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  conciliations  Conciliation[]

  @@unique([invoiceNumber, supplierId])  // Permet nulls: dues factures amb supplierId=null i diferent invoiceNumber no xoquen
  @@index([status])
  @@index([source])
  @@index([issueDate])
  @@index([supplierId])
  @@map("received_invoices")
}

// ===========================================
// Factures Emeses (a clients)
// ===========================================

model IssuedInvoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  clientId        String
  issueDate       DateTime
  dueDate         DateTime?
  subtotal        Decimal       @db.Decimal(12, 2)
  taxRate         Decimal       @default(21) @db.Decimal(5, 2)
  taxAmount       Decimal       @db.Decimal(12, 2)
  totalAmount     Decimal       @db.Decimal(12, 2)
  currency        String        @default("EUR")
  status          InvoiceStatus @default(PENDING)
  category        String?
  description     String?
  filePath        String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relacions
  client         Client          @relation(fields: [clientId], references: [id])
  conciliations  Conciliation[]

  @@index([status])
  @@index([issueDate])
  @@index([clientId])
  @@map("issued_invoices")
}

// ===========================================
// Moviments Bancaris
// ===========================================

enum MovementType {
  INCOME
  EXPENSE
  TRANSFER
}

model BankMovement {
  id              String       @id @default(cuid())
  date            DateTime
  valueDate       DateTime?
  description     String
  amount          Decimal      @db.Decimal(12, 2)
  balance         Decimal?     @db.Decimal(12, 2)
  type            MovementType
  reference       String?
  bankAccount     String?
  rawData         Json?
  isConciliated   Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relacions
  conciliations  Conciliation[]

  @@index([date])
  @@index([isConciliated])
  @@map("bank_movements")
}

// ===========================================
// Conciliació
// ===========================================

enum ConciliationStatus {
  AUTO_MATCHED
  MANUAL_MATCHED
  CONFIRMED
  REJECTED
}

model Conciliation {
  id                  String              @id @default(cuid())
  bankMovementId      String
  receivedInvoiceId   String?
  issuedInvoiceId     String?
  status              ConciliationStatus  @default(AUTO_MATCHED)
  confidence          Float?
  matchReason         String?
  confirmedBy         String?
  confirmedAt         DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  // Relacions
  bankMovement     BankMovement     @relation(fields: [bankMovementId], references: [id])
  receivedInvoice  ReceivedInvoice? @relation(fields: [receivedInvoiceId], references: [id])
  issuedInvoice    IssuedInvoice?   @relation(fields: [issuedInvoiceId], references: [id])

  @@index([bankMovementId])
  @@index([receivedInvoiceId])
  @@index([issuedInvoiceId])
  @@map("conciliations")
}

// ===========================================
// Notes (polimòrfiques)
// ===========================================

model Note {
  id          String   @id @default(cuid())
  content     String
  entityType  String   // 'received_invoice', 'issued_invoice', 'bank_movement', 'supplier', 'client', 'conciliation'
  entityId    String
  authorId    String
  isPinned    Boolean  @default(false)
  isInternal  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacions
  author  User @relation(fields: [authorId], references: [id])

  @@index([entityType, entityId])
  @@index([authorId])
  @@map("notes")
}

// ===========================================
// Recordatoris
// ===========================================

enum ReminderPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ReminderRecurrence {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model Reminder {
  id          String              @id @default(cuid())
  title       String
  description String?
  dueAt       DateTime
  priority    ReminderPriority    @default(NORMAL)
  recurrence  ReminderRecurrence?
  isCompleted Boolean             @default(false)
  completedAt DateTime?
  entityType  String?
  entityId    String?
  authorId    String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  // Relacions
  author    User                @relation(fields: [authorId], references: [id])
  mentions  ReminderMention[]

  @@index([dueAt])
  @@index([authorId])
  @@index([isCompleted])
  @@map("reminders")
}

model ReminderMention {
  id          String    @id @default(cuid())
  reminderId  String
  userId      String
  isRead      Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  // Relacions
  reminder  Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([reminderId, userId])
  @@index([userId, isRead])
  @@map("reminder_mentions")
}

// ===========================================
// Registre d'Activitat
// ===========================================

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String
  userId      String?
  metadata    Json?
  createdAt   DateTime @default(now())

  // Relacions
  user  User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}
