// ===========================================
// SeitoCamera Admin — Schema Prisma
// ===========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
// Usuaris i Autenticació
// ===========================================

enum Role {
  ADMIN
  EDITOR
  VIEWER
  CUSTOM
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String
  role          Role     @default(VIEWER)
  // Permisos personalitzats per usuari (només s'usa quan role = CUSTOM)
  // Format: { "sectionKey": "read" | "write" | "admin" }
  // Seccions: dashboard, receivedInvoices, issuedInvoices, suppliers,
  // clients, bank, conciliation, reminders
  customPermissions Json?
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relacions
  notes             Note[]
  reminders         Reminder[]
  reminderMentions  ReminderMention[]
  activityLogs      ActivityLog[]
  agentChats        AgentChat[]
  lockedPeriods       SharedPeriodLock[] @relation("lockedPeriods")
  compensatedPeriods  SharedPeriodLock[] @relation("compensatedPeriods")

  @@map("users")
}

// ===========================================
// Proveïdors i Clients
// ===========================================

model Supplier {
  id          String   @id @default(cuid())
  name        String
  nif         String?  @unique
  email       String?
  phone       String?
  address     String?
  city        String?
  postalCode  String?
  country     String   @default("ES")
  notes       String?
  isActive    Boolean  @default(true)
  requiresManualDownload Boolean @default(false)  // Cal entrar a la web del proveïdor a descarregar factures
  manualDownloadUrl      String?                  // URL de la web del proveïdor per descarregar factures
  isSharedDefault       Boolean  @default(false)  // Si les factures d'aquest proveïdor són compartides per defecte
  sharedPercentSeito    Decimal  @default(50) @db.Decimal(5, 2)  // % Seito per defecte
  sharedPercentLogistik Decimal  @default(50) @db.Decimal(5, 2)  // % Logistik per defecte
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacions
  receivedInvoices  ReceivedInvoice[]
  template          SupplierTemplate?
  equipment         Equipment[]

  @@map("suppliers")
}

// ===========================================
// Plantilles de proveïdor (patrons apresos)
// ===========================================
model SupplierTemplate {
  id              String   @id @default(cuid())
  supplierId      String   @unique

  // Patrons de número de factura apresos
  // Ex: ["^FRA-\\d{4,}", "^\\d{4}/\\d+$"] — regex que encaixen amb els números d'aquest proveïdor
  invoicePatterns Json?    // String[] de regex patterns

  // Prefix comú del número de factura (ex: "FRA-", "2026/")
  invoicePrefix   String?

  // Patrons de nom de fitxer que identifiquen aquest proveïdor
  // Ex: ["Fra_Cromalite", "cromalite", "CROMALITE"]
  filePatterns    Json?    // String[] de patrons de nom de fitxer

  // NIFs detectats als PDFs d'aquest proveïdor
  knownNifs       Json?    // String[] de NIFs

  // Rang d'imports habituals
  avgAmount       Decimal? @db.Decimal(12, 2)
  minAmount       Decimal? @db.Decimal(12, 2)
  maxAmount       Decimal? @db.Decimal(12, 2)

  // IVA habitual
  commonTaxRate   Decimal? @db.Decimal(5, 2)

  // Nombre de factures analitzades per generar la plantilla
  sampleCount     Int      @default(0)

  // Confiança global de la plantilla (0-1)
  confidence      Float    @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relació
  supplier        Supplier @relation(fields: [supplierId], references: [id])

  @@map("supplier_templates")
}

model Client {
  id          String   @id @default(cuid())
  name        String
  nif         String?  @unique
  email       String?
  phone       String?
  address     String?
  city        String?
  postalCode  String?
  country     String   @default("ES")
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacions
  issuedInvoices  IssuedInvoice[]

  @@map("clients")
}

// ===========================================
// Factures Rebudes (de proveïdors)
// ===========================================

enum InvoiceStatus {
  PENDING
  PDF_PENDING
  AMOUNT_PENDING
  REVIEWED
  APPROVED
  REJECTED
  PAID
  PARTIALLY_PAID
  NOT_INVOICE       // Document que no és una factura real
}

enum InvoiceSource {
  MANUAL          // Creada manualment des del panell
  EMAIL_WITH_PDF  // Via Zoho Mail amb PDF adjunt
  EMAIL_NO_PDF    // Via Zoho Mail sense PDF (notificació)
  GDRIVE_SYNC     // Pujada manualment a Google Drive i sincronitzada
  BANK_DETECTED   // Detectada a partir d'un moviment bancari
}

model ReceivedInvoice {
  id                String        @id @default(cuid())
  invoiceNumber     String
  supplierId        String?
  issueDate         DateTime
  dueDate           DateTime?
  subtotal          Decimal       @db.Decimal(12, 2)
  taxRate           Decimal       @default(21) @db.Decimal(5, 2)
  taxAmount         Decimal       @db.Decimal(12, 2)
  irpfRate          Decimal       @default(0) @db.Decimal(5, 2)  // % retenció IRPF (7%, 15%, etc.)
  irpfAmount        Decimal       @default(0) @db.Decimal(12, 2) // Import retenció IRPF
  totalAmount       Decimal       @db.Decimal(12, 2)             // = subtotal + taxAmount - irpfAmount
  currency          String        @default("EUR")
  status            InvoiceStatus @default(PENDING)
  source            InvoiceSource @default(MANUAL)
  category          String?
  description       String?
  ocrRawData        Json?
  ocrConfidence     Float?
  originalFileName  String?
  filePath          String?
  gdriveFileId      String?       // ID del fitxer a Google Drive
  emailMessageId    String?
  isDuplicate       Boolean       @default(false)
  duplicateOfId     String?       // ID de la factura original si és duplicat
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?     // Soft delete: paperera (null = activa, data = eliminada)

  // Classificació comptable (agent)
  accountingType    String?       // 'EXPENSE' (despesa directa) o 'INVESTMENT' (inversió/immobilitzat)
  pgcAccount        String?       // Compte PGC: "621", "628", "213", etc.
  pgcAccountName    String?       // Nom: "Arrendaments", "Subministraments", etc.
  classifiedBy      String?       // 'AGENT_AUTO', 'AGENT_CHAT', 'MANUAL'
  classifiedAt      DateTime?

  // Extracció d'equips
  equipmentExtracted  Boolean   @default(false)  // Si ja s'ha intentat extreure equips

  // Factura compartida SEITO-LOGISTIK
  isShared              Boolean  @default(false)   // Si la factura es reparteix entre dues empreses
  sharedPercentSeito    Decimal  @default(50) @db.Decimal(5, 2)  // % que paga Seito
  sharedPercentLogistik Decimal  @default(50) @db.Decimal(5, 2)  // % que paga Logistik

  // Origen i pagament de la factura
  origin                String   @default("SEITO")   // SEITO, LOGISTIK, SHARED
  paidBy                String   @default("NONE")     // NONE, SEITO, LOGISTIK

  // Relacions
  supplier         Supplier?          @relation(fields: [supplierId], references: [id])
  conciliations    Conciliation[]
  agentSuggestions AgentSuggestion[]
  equipment        Equipment[]

  @@unique([invoiceNumber, supplierId])  // Permet nulls: dues factures amb supplierId=null i diferent invoiceNumber no xoquen
  @@index([status])
  @@index([source])
  @@index([issueDate])
  @@index([supplierId])
  @@index([accountingType])
  @@index([origin])
  @@index([deletedAt])
  @@index([isShared])
  @@map("received_invoices")
}

// ===========================================
// Factures Emeses (a clients)
// ===========================================

model IssuedInvoice {
  id                String        @id @default(cuid())
  invoiceNumber     String        @unique
  clientId          String
  issueDate         DateTime
  dueDate           DateTime?
  subtotal          Decimal       @db.Decimal(12, 2)
  taxRate           Decimal       @default(21) @db.Decimal(5, 2)
  taxAmount         Decimal       @db.Decimal(12, 2)
  totalAmount       Decimal       @db.Decimal(12, 2)
  currency          String        @default("EUR")
  status            InvoiceStatus @default(PENDING)
  category          String?
  description       String?
  projectReference  String?       // Referència del projecte Rentman ({$f.project.reference})
  projectName       String?       // Nom del projecte Rentman
  rentmanInvoiceId  String?       // ID original de la factura a Rentman (per resync / backfill)
  rentmanProjectId  String?       // ID del projecte a Rentman
  filePath          String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relacions
  client         Client          @relation(fields: [clientId], references: [id])
  conciliations  Conciliation[]

  @@index([status])
  @@index([issueDate])
  @@index([clientId])
  @@index([rentmanInvoiceId])
  @@map("issued_invoices")
}

// ===========================================
// Moviments Bancaris
// ===========================================

enum MovementType {
  INCOME
  EXPENSE
  TRANSFER
}

model BankMovement {
  id              String       @id @default(cuid())
  date            DateTime
  valueDate       DateTime?
  description     String
  amount          Decimal      @db.Decimal(12, 2)
  balance         Decimal?     @db.Decimal(12, 2)
  type            MovementType
  reference       String?
  bankAccount     String?
  counterparty    String?              // Nom del pagador/cobrador (Qonto)
  accountName     String?              // Compte: GASTOS, Ingresos, ESTALVI
  category        String?              // Categoria de Qonto
  operationType   String?              // income, transfer, direct_debit, other
  qontoSlug       String?    @unique   // ID únic de Qonto per evitar duplicats
  rawData         Json?
  isConciliated   Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relacions
  conciliations  Conciliation[]

  @@index([date])
  @@index([isConciliated])
  @@index([accountName])
  @@map("bank_movements")
}

// ===========================================
// Conciliació
// ===========================================

enum ConciliationStatus {
  AUTO_MATCHED
  MANUAL_MATCHED
  CONFIRMED
  REJECTED
}

model Conciliation {
  id                  String              @id @default(cuid())
  bankMovementId      String
  receivedInvoiceId   String?
  issuedInvoiceId     String?
  status              ConciliationStatus  @default(AUTO_MATCHED)
  confidence          Float?
  matchReason         String?
  confirmedBy         String?
  confirmedAt         DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  // Relacions
  bankMovement     BankMovement     @relation(fields: [bankMovementId], references: [id])
  receivedInvoice  ReceivedInvoice? @relation(fields: [receivedInvoiceId], references: [id])
  issuedInvoice    IssuedInvoice?   @relation(fields: [issuedInvoiceId], references: [id])

  @@index([bankMovementId])
  @@index([receivedInvoiceId])
  @@index([issuedInvoiceId])
  @@map("conciliations")
}

// ===========================================
// Notes (polimòrfiques)
// ===========================================

model Note {
  id          String   @id @default(cuid())
  content     String
  entityType  String   // 'received_invoice', 'issued_invoice', 'bank_movement', 'supplier', 'client', 'conciliation'
  entityId    String
  authorId    String
  isPinned    Boolean  @default(false)
  isInternal  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacions
  author  User @relation(fields: [authorId], references: [id])

  @@index([entityType, entityId])
  @@index([authorId])
  @@map("notes")
}

// ===========================================
// Recordatoris
// ===========================================

enum ReminderPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ReminderRecurrence {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model Reminder {
  id          String              @id @default(cuid())
  title       String
  description String?
  dueAt       DateTime
  priority    ReminderPriority    @default(NORMAL)
  recurrence  ReminderRecurrence?
  isCompleted Boolean             @default(false)
  completedAt DateTime?
  entityType  String?
  entityId    String?
  authorId    String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  // Relacions
  author    User                @relation(fields: [authorId], references: [id])
  mentions  ReminderMention[]

  @@index([dueAt])
  @@index([authorId])
  @@index([isCompleted])
  @@map("reminders")
}

model ReminderMention {
  id          String    @id @default(cuid())
  reminderId  String
  userId      String
  isRead      Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  // Relacions
  reminder  Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([reminderId, userId])
  @@index([userId, isRead])
  @@map("reminder_mentions")
}

// ===========================================
// Registre d'Activitat
// ===========================================

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String
  userId      String?
  metadata    Json?
  createdAt   DateTime @default(now())

  // Relacions
  user  User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ===========================================
// Agent Comptable — Xat
// ===========================================

model AgentChat {
  id          String   @id @default(cuid())
  userId      String
  title       String?        // Resum generat automàticament de la conversa
  messages    Json           // Array de { role: 'user'|'assistant', content: string, timestamp: string }
  context     Json?          // Dades de context usades (IDs factures, filters, etc.)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacions
  user  User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("agent_chats")
}

// ===========================================
// Agent Comptable — Suggeriments
// ===========================================

enum SuggestionType {
  CLASSIFICATION        // Classificació despesa vs inversió
  PGC_ACCOUNT           // Assignació compte PGC
  ANOMALY               // Detecció d'anomalia
  DUPLICATE             // Possible duplicat
  MISSING_DATA          // Dades que falten
  TAX_WARNING           // IVA incorrecte o inusual
}

enum SuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

model AgentSuggestion {
  id                  String           @id @default(cuid())
  receivedInvoiceId   String
  type                SuggestionType
  status              SuggestionStatus @default(PENDING)
  title               String           // Títol curt del suggeriment
  description         String           // Explicació detallada
  suggestedValue      Json?            // Valor suggerit: { accountingType, pgcAccount, pgcAccountName, ... }
  confidence          Float?           // 0-1 confiança del suggeriment
  reasoning           String?          // Raonament de l'agent
  resolvedBy          String?          // 'user' o 'auto'
  resolvedAt          DateTime?
  createdAt           DateTime         @default(now())

  // Relacions
  receivedInvoice  ReceivedInvoice @relation(fields: [receivedInvoiceId], references: [id])

  @@index([receivedInvoiceId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@map("agent_suggestions")
}

// ===========================================
// Inventari d'Equips
// ===========================================

model Equipment {
  id                  String   @id @default(cuid())
  name                String           // Nom del producte/model (ex: "Sony FX6", "Canon RF 24-70mm f/2.8")
  serialNumber        String?          // Número de sèrie
  category            String?          // camera, lens, lighting, audio, accessory, other
  brand               String?          // Marca extreta
  model               String?          // Model específic
  purchasePrice       Decimal? @db.Decimal(12, 2)  // Preu de compra unitari
  purchaseDate        DateTime?        // Data de compra (= issueDate de la factura)
  status              String   @default("ACTIVE")   // ACTIVE, SOLD, BROKEN, LOST
  notes               String?
  extractedBy         String   @default("MANUAL")   // MANUAL, AGENT_AUTO, AGENT_MANUAL
  rawExtractedData    Json?            // Dades brutes de l'extracció (línia original del PDF)

  // Relacions
  receivedInvoiceId   String?
  supplierId          String?
  receivedInvoice     ReceivedInvoice? @relation(fields: [receivedInvoiceId], references: [id])
  supplier            Supplier?        @relation(fields: [supplierId], references: [id])

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([receivedInvoiceId])
  @@index([supplierId])
  @@index([serialNumber])
  @@index([category])
  @@index([status])
  @@map("equipment")
}

// ===========================================
// Registre d'ús d'IA (costos Claude API)
// ===========================================

model AiUsageLog {
  id              String   @id @default(cuid())
  timestamp       DateTime @default(now())
  service         String   // 'email_classification', 'invoice_extraction', 'accounting_agent', 'equipment_extraction'
  model           String   // 'claude-haiku-4-5-20251001', etc.
  inputTokens     Int      @default(0)
  outputTokens    Int      @default(0)
  costUsd         Float    @default(0) // cost estimat en USD
  entityType      String?  // 'email', 'invoice', 'equipment'
  entityId        String?  // ID del correu, factura, etc.
  success         Boolean  @default(true)
  metadata        Json?    // dades extra (subject, fileName, etc.)

  @@index([timestamp])
  @@index([service])
  @@index([timestamp, service])
  @@map("ai_usage_logs")
}

model SharedPeriodLock {
  id                  String    @id @default(cuid())
  year                Int
  period              String    // "01".."12" (mes) o "Q1".."Q4" (trimestre)
  periodType          String    // "month" o "quarter"

  // Bloqueig
  locked              Boolean   @default(false)
  lockedAt            DateTime?
  lockedBy            String?   // userId

  // Compensació
  compensated         Boolean   @default(false)
  compensatedAt       DateTime?
  compensatedBy       String?   // userId
  compensatedDirection String?  // "SEITO_PAYS_LOGISTIK" o "LOGISTIK_PAYS_SEITO"
  compensatedAmount   Decimal?  @db.Decimal(12, 2)
  balanceSeito        Decimal?  @db.Decimal(12, 2) // total que ha pagat Seito
  balanceLogistik     Decimal?  @db.Decimal(12, 2) // total que ha pagat Logistik

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relació amb l'usuari que ha bloquejat/compensat
  lockedByUser        User?     @relation("lockedPeriods", fields: [lockedBy], references: [id])
  compensatedByUser   User?     @relation("compensatedPeriods", fields: [compensatedBy], references: [id])

  @@unique([year, period, periodType])
  @@map("shared_period_locks")
}
