// ===========================================
// SeitoCamera Admin — Schema Prisma
// ===========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
// Usuaris i Autenticació
// ===========================================

enum Role {
  ADMIN
  EDITOR
  VIEWER
  CUSTOM
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String
  role          Role     @default(VIEWER)
  color         String?  // Color diferenciat per l'usuari (hex, ex: #3B82F6)
  // Permisos personalitzats per usuari (només s'usa quan role = CUSTOM)
  // Format: { "sectionKey": "read" | "write" | "admin" }
  // Seccions: dashboard, receivedInvoices, issuedInvoices, suppliers,
  // clients, bank, conciliation, reminders
  customPermissions Json?
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relacions
  notes             Note[]
  reminders         Reminder[]
  reminderMentions  ReminderMention[]
  activityLogs      ActivityLog[]
  agentChats        AgentChat[]
  lockedPeriods         SharedPeriodLock[] @relation("lockedPeriods")
  compensatedPeriods    SharedPeriodLock[] @relation("compensatedPeriods")
  paymentReminders      PaymentReminderLog[]

  // Mòdul Operacions
  roleAssignments       RoleAssignment[]
  projectAssignments    ProjectAssignment[]
  ledProjects           RentalProject[]   @relation("ProjectLead")
  techSupportProjects   RentalProject[]   @relation("ProjectTechSupport")
  returnLeadProjects    RentalProject[]   @relation("ProjectReturnLead")
  createdTasks          ProjectTask[]     @relation("TaskCreator")
  assignedTasks         ProjectTask[]     @relation("TaskAssignee")
  completedTasks        ProjectTask[]     @relation("TaskCompleter")
  checklistsCompleted   TaskChecklistItem[] @relation("ChecklistCompleter")
  createdTemplates      TaskTemplate[]    @relation("TemplateCreator")
  taskComments          TaskComment[]     @relation("TaskCommenter")
  taskActivities        TaskActivity[]    @relation("TaskActivityUser")
  agentRules            AgentRule[]       @relation("agentRulesCreated")
  absences              StaffAbsence[]    @relation("AbsenceUser")
  approvedAbsences      StaffAbsence[]    @relation("AbsenceApprover")
  timeEntries           TimeEntry[]       @relation("TimeEntryUser")
  approvedTimeEntries   TimeEntry[]       @relation("TimeEntryApprover")
  pushSubscriptions     PushSubscription[]
  transportsCreated     Transport[]        @relation("transportCreatedBy")
  conductorProfile      Conductor?         @relation("ConductorUser")

  // Mòdul Comptabilitat formal
  fiscalYearsLocked     FiscalYear[]       @relation("fiscalYearLocked")
  auditLogs             AuditLog[]
  journalEntriesCreated JournalEntry[]     @relation("journalCreated")
  journalEntriesPosted  JournalEntry[]     @relation("journalPosted")

  @@map("users")
}

// ===========================================
// Proveïdors i Clients
// ===========================================

model Supplier {
  id          String   @id @default(cuid())
  name        String
  nif         String?  @unique
  email       String?
  phone       String?
  address     String?
  city        String?
  postalCode  String?
  country     String   @default("ES")
  notes       String?
  isActive    Boolean  @default(true)
  requiresManualDownload Boolean @default(false)  // Cal entrar a la web del proveïdor a descarregar factures
  manualDownloadUrl      String?                  // URL de la web del proveïdor per descarregar factures
  isSharedDefault       Boolean  @default(false)  // Si les factures d'aquest proveïdor són compartides per defecte
  sharedPercentSeito    Decimal  @default(50) @db.Decimal(5, 2)  // % Seito per defecte
  sharedPercentLogistik Decimal  @default(50) @db.Decimal(5, 2)  // % Logistik per defecte
  isPublicAdmin         Boolean  @default(false)  // Administració Pública (AEAT, SS, Generalitat...) — apareix a "Comptes públics"

  // Vincle comptabilitat formal (Sprint 3)
  defaultExpenseAccountId String?              // Subcompte despesa habitual (629, 623, etc.)
  counterpartyAccountId   String?  @unique     // Subcompte 410xxxx propi

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacions
  receivedInvoices  ReceivedInvoice[]
  template          SupplierTemplate?
  equipment         Equipment[]
  counterpartyMaps  CounterpartyMap[]
  defaultExpenseAccount ChartOfAccount? @relation("SupplierDefaultExpense", fields: [defaultExpenseAccountId], references: [id])
  counterpartyAccount   ChartOfAccount? @relation("SupplierCounterparty", fields: [counterpartyAccountId], references: [id])

  @@index([isPublicAdmin])
  @@index([defaultExpenseAccountId])
  @@map("suppliers")
}

// ===========================================
// Plantilles de proveïdor (patrons apresos)
// ===========================================
model SupplierTemplate {
  id              String   @id @default(cuid())
  supplierId      String   @unique

  // Patrons de número de factura apresos
  // Ex: ["^FRA-\\d{4,}", "^\\d{4}/\\d+$"] — regex que encaixen amb els números d'aquest proveïdor
  invoicePatterns Json?    // String[] de regex patterns

  // Prefix comú del número de factura (ex: "FRA-", "2026/")
  invoicePrefix   String?

  // Patrons de nom de fitxer que identifiquen aquest proveïdor
  // Ex: ["Fra_Cromalite", "cromalite", "CROMALITE"]
  filePatterns    Json?    // String[] de patrons de nom de fitxer

  // NIFs detectats als PDFs d'aquest proveïdor
  knownNifs       Json?    // String[] de NIFs

  // Rang d'imports habituals
  avgAmount       Decimal? @db.Decimal(12, 2)
  minAmount       Decimal? @db.Decimal(12, 2)
  maxAmount       Decimal? @db.Decimal(12, 2)

  // IVA habitual
  commonTaxRate   Decimal? @db.Decimal(5, 2)

  // Nombre de factures analitzades per generar la plantilla
  sampleCount     Int      @default(0)

  // Confiança global de la plantilla (0-1)
  confidence      Float    @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relació
  supplier        Supplier @relation(fields: [supplierId], references: [id])

  @@map("supplier_templates")
}

model Client {
  id          String   @id @default(cuid())
  name        String
  nif         String?  @unique
  email       String?
  phone       String?
  address     String?
  city        String?
  postalCode  String?
  country     String   @default("ES")
  notes       String?
  isActive    Boolean  @default(true)

  // Vincle comptabilitat formal (Sprint 3)
  defaultRevenueAccountId String?              // Subcompte ingrés habitual (705, 700, etc.)
  counterpartyAccountId   String?  @unique     // Subcompte 430xxxx propi

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacions
  issuedInvoices    IssuedInvoice[]
  counterpartyMaps  CounterpartyMap[]
  rentalProjects    RentalProject[]
  defaultRevenueAccount ChartOfAccount? @relation("ClientDefaultRevenue", fields: [defaultRevenueAccountId], references: [id])
  counterpartyAccount   ChartOfAccount? @relation("ClientCounterparty", fields: [counterpartyAccountId], references: [id])

  @@index([defaultRevenueAccountId])
  @@map("clients")
}

// ===========================================
// Factures Rebudes (de proveïdors)
// ===========================================

enum InvoiceStatus {
  PENDING
  PDF_PENDING
  AMOUNT_PENDING
  REVIEWED
  APPROVED
  REJECTED
  PAID
  PARTIALLY_PAID
  NOT_INVOICE       // Document que no és una factura real
}

enum InvoiceSource {
  MANUAL          // Creada manualment des del panell
  EMAIL_WITH_PDF  // Via Zoho Mail amb PDF adjunt
  EMAIL_NO_PDF    // Via Zoho Mail sense PDF (notificació)
  GDRIVE_SYNC     // Pujada manualment a Google Drive i sincronitzada
  BANK_DETECTED   // Detectada a partir d'un moviment bancari
}

model ReceivedInvoice {
  id                String        @id @default(cuid())
  invoiceNumber     String
  supplierId        String?
  issueDate         DateTime
  dueDate           DateTime?
  subtotal          Decimal       @db.Decimal(12, 2)
  taxRate           Decimal       @default(21) @db.Decimal(5, 2)
  taxAmount         Decimal       @db.Decimal(12, 2)
  irpfRate          Decimal       @default(0) @db.Decimal(5, 2)  // % retenció IRPF (7%, 15%, etc.)
  irpfAmount        Decimal       @default(0) @db.Decimal(12, 2) // Import retenció IRPF
  totalAmount       Decimal       @db.Decimal(12, 2)             // = subtotal + taxAmount - irpfAmount
  currency          String        @default("EUR")
  status            InvoiceStatus @default(PENDING)
  source            InvoiceSource @default(MANUAL)
  category          String?
  description       String?
  ocrRawData        Json?
  ocrConfidence     Float?
  originalFileName  String?
  filePath          String?
  gdriveFileId      String?       // ID del fitxer a Google Drive
  emailMessageId    String?
  isDateEstimated   Boolean       @default(false)  // true si issueDate és fallback (data pujada, no extreta del PDF)
  isDuplicate       Boolean       @default(false)
  duplicateOfId     String?       // ID de la factura original si és duplicat
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?     // Soft delete: paperera (null = activa, data = eliminada)

  // Classificació comptable (agent)
  accountingType    String?       // 'EXPENSE' (despesa directa) o 'INVESTMENT' (inversió/immobilitzat)
  pgcAccount        String?       // Compte PGC: "621", "628", "213", etc.
  pgcAccountName    String?       // Nom: "Arrendaments", "Subministraments", etc.
  classifiedBy      String?       // 'AGENT_AUTO', 'AGENT_CHAT', 'MANUAL'
  classifiedAt      DateTime?

  // Extracció d'equips
  equipmentExtracted  Boolean   @default(false)  // Si ja s'ha intentat extreure equips

  // Factura compartida SEITO-LOGISTIK
  isShared              Boolean  @default(false)   // Si la factura es reparteix entre dues empreses
  sharedPercentSeito    Decimal  @default(50) @db.Decimal(5, 2)  // % que paga Seito
  sharedPercentLogistik Decimal  @default(50) @db.Decimal(5, 2)  // % que paga Logistik

  // Origen i pagament de la factura
  origin                String   @default("SEITO")   // SEITO, LOGISTIK, SHARED
  paidBy                String   @default("NONE")     // NONE, SEITO, LOGISTIK

  // Pagaments parcials
  paidAmount            Decimal  @default(0) @db.Decimal(12, 2) // Import ja cobrat (per pagaments parcials)

  // Vincle comptabilitat formal (Sprint 3)
  companyId               String?
  accountId               String?   // Subcompte de despesa o immobilitzat (substitueix pgcAccount text)
  counterpartyAccountId   String?   // Subcompte 410xxxx del proveïdor
  journalEntryId          String?   @unique
  postedAt                DateTime?

  // Relacions
  supplier         Supplier?          @relation(fields: [supplierId], references: [id])
  conciliations    Conciliation[]
  agentSuggestions AgentSuggestion[]
  equipment        Equipment[]
  company             Company?         @relation(fields: [companyId], references: [id])
  account             ChartOfAccount?  @relation("ReceivedInvoiceAccount", fields: [accountId], references: [id])
  counterpartyAccount ChartOfAccount?  @relation("ReceivedInvoiceCounterparty", fields: [counterpartyAccountId], references: [id])
  journalEntry        JournalEntry?    @relation("ReceivedInvoiceJournal", fields: [journalEntryId], references: [id])

  @@unique([invoiceNumber, supplierId])  // Permet nulls: dues factures amb supplierId=null i diferent invoiceNumber no xoquen
  @@index([status])
  @@index([source])
  @@index([issueDate])
  @@index([supplierId])
  @@index([accountingType])
  @@index([origin])
  @@index([deletedAt])
  @@index([isShared])
  @@index([companyId])
  @@index([accountId])
  @@index([postedAt])
  @@map("received_invoices")
}

// ===========================================
// Factures Emeses (a clients)
// ===========================================

model IssuedInvoice {
  id                String        @id @default(cuid())
  invoiceNumber     String        @unique
  clientId          String
  issueDate         DateTime
  dueDate           DateTime?
  subtotal          Decimal       @db.Decimal(12, 2)
  taxRate           Decimal       @default(21) @db.Decimal(5, 2)
  taxAmount         Decimal       @db.Decimal(12, 2)
  totalAmount       Decimal       @db.Decimal(12, 2)
  currency          String        @default("EUR")
  status            InvoiceStatus @default(PENDING)
  category          String?
  description       String?
  projectReference  String?       // Referència del projecte Rentman ({$f.project.reference})
  projectName       String?       // Nom del projecte Rentman
  rentmanInvoiceId  String?       // ID original de la factura a Rentman (per resync / backfill)
  rentmanProjectId  String?       // ID del projecte a Rentman
  filePath          String?
  paidAmount        Decimal       @default(0) @db.Decimal(12, 2) // Import ja cobrat (per pagaments parcials)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Vincle comptabilitat formal (Sprint 3)
  companyId               String?
  accountId               String?    // Subcompte d'ingrés (705, 700, etc.)
  counterpartyAccountId   String?    // Subcompte 430xxxx del client
  journalEntryId          String?    @unique
  postedAt                DateTime?

  // Relacions
  client              Client                @relation(fields: [clientId], references: [id])
  conciliations       Conciliation[]
  paymentReminders    PaymentReminderLog[]
  company             Company?              @relation(fields: [companyId], references: [id])
  account             ChartOfAccount?       @relation("IssuedInvoiceAccount", fields: [accountId], references: [id])
  counterpartyAccount ChartOfAccount?       @relation("IssuedInvoiceCounterparty", fields: [counterpartyAccountId], references: [id])
  journalEntry        JournalEntry?         @relation("IssuedInvoiceJournal", fields: [journalEntryId], references: [id])

  @@index([status])
  @@index([issueDate])
  @@index([clientId])
  @@index([companyId])
  @@index([accountId])
  @@index([postedAt])
  @@index([rentmanInvoiceId])
  @@map("issued_invoices")
}

// ===========================================
// Historial de recordatoris de cobrament
// ===========================================
model PaymentReminderLog {
  id              String        @id @default(cuid())
  issuedInvoiceId String
  sentTo          String        // Email destinatari
  sentBy          String        // userId de qui ho envia
  subject         String?
  notes           String?
  createdAt       DateTime      @default(now())

  // Relacions
  issuedInvoice   IssuedInvoice @relation(fields: [issuedInvoiceId], references: [id], onDelete: Cascade)
  user            User          @relation(fields: [sentBy], references: [id])

  @@index([issuedInvoiceId])
  @@map("payment_reminder_logs")
}

// ===========================================
// Connexions de serveis externs (OAuth, API keys)
// ===========================================

enum ServiceProvider {
  ZOHO_MAIL
  GOOGLE_DRIVE
  QONTO
  GOCARDLESS
  RENTMAN
  SMTP
  SHELLY
}

enum ConnectionStatus {
  ACTIVE
  EXPIRED
  ERROR
  DISCONNECTED
}

model ServiceConnection {
  id            String           @id @default(cuid())
  provider      ServiceProvider  @unique  // Un sol registre per proveïdor
  status        ConnectionStatus @default(DISCONNECTED)
  displayName   String?                  // "Zoho Mail - rental@seitocamera.com"

  // OAuth2 credentials (Zoho, Google, etc.)
  clientId      String?
  clientSecret  String?
  refreshToken  String?
  accessToken   String?
  tokenExpiresAt DateTime?
  scopes        String?                  // Scopes concedits, separats per coma

  // API key credentials (Qonto, Rentman, etc.)
  apiKey        String?
  apiSecret     String?

  // Config extra (JSON flexible per cada proveïdor)
  config        Json?                    // { accountId, fromAddress, host, port, ... }

  // Metadades
  connectedBy   String?                  // userId de qui l'ha connectat
  connectedAt   DateTime?
  lastUsedAt    DateTime?
  lastError     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@map("service_connections")
}

// ===========================================
// Moviments Bancaris
// ===========================================

enum MovementType {
  INCOME
  EXPENSE
  TRANSFER
}

enum BankSyncType {
  MANUAL
  CSV
  QONTO
  OPEN_BANKING
}

model BankAccount {
  id            String       @id @default(cuid())
  name          String                // "Qonto Principal", "Sabadell Empresa"
  iban          String?               // ES12 3456 7890 1234 5678 90
  bankEntity    String?               // "Qonto", "Banc Sabadell", "CaixaBank"
  syncType      BankSyncType @default(MANUAL)
  color         String       @default("#2390A0")  // Color per distingir comptes
  isActive      Boolean      @default(true)
  isDefault     Boolean      @default(false)      // Compte per defecte
  syncConfig    Json?                              // Config connexió: { orgSlug, secretKey } (Qonto) o { requisitionId, accountId, secretId, secretKey } (GoCardless)
  currentBalance Decimal?    @db.Decimal(12, 2)   // Saldo real obtingut via API
  lastSyncAt    DateTime?                          // Última sincronització exitosa
  lastSyncError String?                            // Últim error de sincronització
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Vincle comptabilitat formal (Sprint 4)
  accountId     String?       @unique           // Subcompte 572xxxx representant aquest compte bancari

  // Relacions
  movements     BankMovement[]
  account       ChartOfAccount? @relation("BankAccountAccount", fields: [accountId], references: [id])

  @@map("bank_accounts")
}

model BankMovement {
  id              String        @id @default(cuid())
  date            DateTime
  valueDate       DateTime?
  description     String
  amount          Decimal       @db.Decimal(12, 2)
  balance         Decimal?      @db.Decimal(12, 2)
  type            MovementType
  reference       String?
  bankAccount     String?                          // Camp antic (IBAN text) — mantenim per compatibilitat
  bankAccountId   String?                          // FK al nou model BankAccount
  bankAccountRef  BankAccount?  @relation(fields: [bankAccountId], references: [id])
  counterparty    String?              // Nom del pagador/cobrador (Qonto)
  accountName     String?              // Compte: GASTOS, Ingresos, ESTALVI
  category        String?              // Categoria de Qonto
  operationType   String?              // income, transfer, direct_debit, other
  qontoSlug       String?    @unique   // ID únic de Qonto per evitar duplicats
  rawData         Json?
  isConciliated   Boolean      @default(false)
  isDismissed     Boolean      @default(false)   // Descartat manualment (no cal conciliar)
  dropzoneSentAt  DateTime?    // Data en què s'ha copiat el justificant a la Dropzone de Qonto
  dismissReason   String?                         // Motiu: "transferència interna", "impost", etc.

  // Vincle comptabilitat formal (Sprint 4)
  companyId       String?
  accountId       String?                         // Subcompte 572xxxx del banc d'aquest moviment
  journalEntryId  String?  @unique
  postedAt        DateTime?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relacions
  conciliations  Conciliation[]
  company        Company?         @relation(fields: [companyId], references: [id])
  account        ChartOfAccount?  @relation("BankMovementAccount", fields: [accountId], references: [id])
  journalEntry   JournalEntry?    @relation("BankMovementJournal", fields: [journalEntryId], references: [id])

  @@index([date])
  @@index([isConciliated])
  @@index([isDismissed])
  @@index([accountName])
  @@index([bankAccountId])
  @@index([companyId])
  @@index([postedAt])
  @@map("bank_movements")
}

// ===========================================
// Conciliació
// ===========================================

enum ConciliationStatus {
  AUTO_MATCHED
  MANUAL_MATCHED
  CONFIRMED
  REJECTED
}

model Conciliation {
  id                  String              @id @default(cuid())
  bankMovementId      String
  receivedInvoiceId   String?
  issuedInvoiceId     String?
  status              ConciliationStatus  @default(AUTO_MATCHED)
  confidence          Float?
  matchReason         String?
  confirmedBy         String?
  confirmedAt         DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  // Relacions
  bankMovement     BankMovement     @relation(fields: [bankMovementId], references: [id], onDelete: Cascade)
  receivedInvoice  ReceivedInvoice? @relation(fields: [receivedInvoiceId], references: [id], onDelete: Cascade)
  issuedInvoice    IssuedInvoice?   @relation(fields: [issuedInvoiceId], references: [id], onDelete: Cascade)

  @@index([bankMovementId])
  @@index([receivedInvoiceId])
  @@index([issuedInvoiceId])
  @@map("conciliations")
}

// ===========================================
// Regles de comissions (gateways de pagament)
// ===========================================

model CommissionRule {
  id              String    @id @default(cuid())
  name            String    @unique                // Nom del gateway: "Stripe", "PayPal", "TPV BBVA"
  percentage      Decimal   @default(0) @db.Decimal(5, 3)  // % comissió (ex: 1.400 = 1.4%)
  fixedFee        Decimal   @default(0) @db.Decimal(8, 2)  // Import fix per transacció (ex: 0.25€)
  isActive        Boolean   @default(true)
  keywords        String[]  @default([])           // Paraules clau per detectar al moviment: ["stripe", "paypal"]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("commission_rules")
}

// ===========================================
// Memòria de contraparts (IBAN Memory)
// ===========================================

model CounterpartyMap {
  id              String    @id @default(cuid())
  counterparty    String                           // Nom del contrapart (de Qonto/banc)
  supplierId      String?                          // Proveïdor associat
  clientId        String?                          // Client associat
  matchCount      Int       @default(1)            // Vegades que s'ha conciliat
  lastUsed        DateTime  @default(now())        // Última conciliació
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relacions
  supplier  Supplier? @relation(fields: [supplierId], references: [id])
  client    Client?   @relation(fields: [clientId], references: [id])

  @@unique([counterparty, supplierId])
  @@unique([counterparty, clientId])
  @@index([counterparty])
  @@map("counterparty_map")
}

// ===========================================
// Notes (polimòrfiques)
// ===========================================

model Note {
  id          String   @id @default(cuid())
  content     String
  entityType  String   // 'received_invoice', 'issued_invoice', 'bank_movement', 'supplier', 'client', 'conciliation'
  entityId    String
  authorId    String
  isPinned    Boolean  @default(false)
  isInternal  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacions
  author  User @relation(fields: [authorId], references: [id])

  @@index([entityType, entityId])
  @@index([authorId])
  @@map("notes")
}

// ===========================================
// Recordatoris
// ===========================================

enum ReminderPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum ReminderRecurrence {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

model Reminder {
  id          String              @id @default(cuid())
  title       String
  description String?
  dueAt       DateTime
  priority    ReminderPriority    @default(NORMAL)
  recurrence  ReminderRecurrence?
  isCompleted Boolean             @default(false)
  completedAt DateTime?
  entityType  String?
  entityId    String?
  authorId    String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  // Relacions
  author    User                @relation(fields: [authorId], references: [id])
  mentions  ReminderMention[]

  @@index([dueAt])
  @@index([authorId])
  @@index([isCompleted])
  @@map("reminders")
}

model ReminderMention {
  id          String    @id @default(cuid())
  reminderId  String
  userId      String
  isRead      Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  // Relacions
  reminder  Reminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([reminderId, userId])
  @@index([userId, isRead])
  @@map("reminder_mentions")
}

// ===========================================
// Registre d'Activitat
// ===========================================

model ActivityLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String
  userId      String?
  metadata    Json?
  createdAt   DateTime @default(now())

  // Relacions
  user  User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ===========================================
// Agent Comptable — Xat
// ===========================================

model AgentChat {
  id          String   @id @default(cuid())
  userId      String
  title       String?        // Resum generat automàticament de la conversa
  messages    Json           // Array de { role: 'user'|'assistant', content: string, timestamp: string }
  context     Json?          // Dades de context usades (IDs factures, filters, etc.)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relacions
  user  User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("agent_chats")
}

// ===========================================
// Agent Comptable — Suggeriments
// ===========================================

enum SuggestionType {
  CLASSIFICATION        // Classificació despesa vs inversió
  PGC_ACCOUNT           // Assignació compte PGC
  ANOMALY               // Detecció d'anomalia
  DUPLICATE             // Possible duplicat
  MISSING_DATA          // Dades que falten
  TAX_WARNING           // IVA incorrecte o inusual
  CONCILIATION_MATCH    // Coincidència banc-factura proposada
}

enum SuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

model AgentSuggestion {
  id                  String           @id @default(cuid())
  receivedInvoiceId   String
  type                SuggestionType
  status              SuggestionStatus @default(PENDING)
  title               String           // Títol curt del suggeriment
  description         String           // Explicació detallada
  suggestedValue      Json?            // Valor suggerit: { accountingType, pgcAccount, pgcAccountName, ... }
  confidence          Float?           // 0-1 confiança del suggeriment
  reasoning           String?          // Raonament de l'agent
  resolvedBy          String?          // 'user' o 'auto'
  resolvedAt          DateTime?
  createdAt           DateTime         @default(now())

  // Relacions
  receivedInvoice  ReceivedInvoice @relation(fields: [receivedInvoiceId], references: [id], onDelete: Cascade)

  @@index([receivedInvoiceId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@map("agent_suggestions")
}

// ===========================================
// Inventari d'Equips
// ===========================================

model Equipment {
  id                  String   @id @default(cuid())
  name                String           // Nom del producte/model (ex: "Sony FX6", "Canon RF 24-70mm f/2.8")
  serialNumber        String?          // Número de sèrie
  category            String?          // camera, lens, lighting, audio, accessory, other
  brand               String?          // Marca extreta
  model               String?          // Model específic
  purchasePrice       Decimal? @db.Decimal(12, 2)  // Preu de compra unitari
  purchaseDate        DateTime?        // Data de compra (= issueDate de la factura)
  status              String   @default("ACTIVE")   // ACTIVE, SOLD, BROKEN, LOST
  notes               String?
  extractedBy         String   @default("MANUAL")   // MANUAL, AGENT_AUTO, AGENT_MANUAL
  rawExtractedData    Json?            // Dades brutes de l'extracció (línia original del PDF)

  // Agrupació (pack/kit) — relació pare-fill
  parentId            String?          // Si és subitem, apunta al pare
  parent              Equipment?       @relation("EquipmentGroup", fields: [parentId], references: [id])
  children            Equipment[]      @relation("EquipmentGroup")

  // Relacions
  receivedInvoiceId   String?
  supplierId          String?
  receivedInvoice     ReceivedInvoice? @relation(fields: [receivedInvoiceId], references: [id])
  supplier            Supplier?        @relation(fields: [supplierId], references: [id])

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Mòdul Operacions
  projectEquipment    ProjectEquipment[]
  incidents           Incident[]

  @@index([parentId])
  @@index([receivedInvoiceId])
  @@index([supplierId])
  @@index([serialNumber])
  @@index([category])
  @@index([status])
  @@map("equipment")
}

// ===========================================
// Registre d'ús d'IA (costos Claude API)
// ===========================================

model AiUsageLog {
  id              String   @id @default(cuid())
  timestamp       DateTime @default(now())
  service         String   // 'email_classification', 'invoice_extraction', 'accounting_agent', 'equipment_extraction'
  model           String   // 'claude-haiku-4-5-20251001', etc.
  inputTokens     Int      @default(0)
  outputTokens    Int      @default(0)
  costUsd         Float    @default(0) // cost estimat en USD
  entityType      String?  // 'email', 'invoice', 'equipment'
  entityId        String?  // ID del correu, factura, etc.
  success         Boolean  @default(true)
  metadata        Json?    // dades extra (subject, fileName, etc.)

  @@index([timestamp])
  @@index([service])
  @@index([timestamp, service])
  @@map("ai_usage_logs")
}

model SharedPeriodLock {
  id                  String    @id @default(cuid())
  year                Int
  period              String    // "01".."12" (mes) o "Q1".."Q4" (trimestre)
  periodType          String    // "month" o "quarter"

  // Bloqueig
  locked              Boolean   @default(false)
  lockedAt            DateTime?
  lockedBy            String?   // userId

  // Compensació
  compensated         Boolean   @default(false)
  compensatedAt       DateTime?
  compensatedBy       String?   // userId
  compensatedDirection String?  // "SEITO_PAYS_LOGISTIK" o "LOGISTIK_PAYS_SEITO"
  compensatedAmount   Decimal?  @db.Decimal(12, 2)
  balanceSeito        Decimal?  @db.Decimal(12, 2) // total que ha pagat Seito
  balanceLogistik     Decimal?  @db.Decimal(12, 2) // total que ha pagat Logistik

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relació amb l'usuari que ha bloquejat/compensat
  lockedByUser        User?     @relation("lockedPeriods", fields: [lockedBy], references: [id])
  compensatedByUser   User?     @relation("compensatedPeriods", fields: [compensatedBy], references: [id])

  @@unique([year, period, periodType])
  @@map("shared_period_locks")
}

// ===========================================
// Mòdul Protocol d'Empresa — Enums
// ===========================================

enum OperationalRole {
  ADMIN_COORDINATION     // Administració i coordinació externa
  WAREHOUSE_LEAD         // Responsable principal de magatzem
  WAREHOUSE_SUPPORT      // Responsable de magatzem / suport operatiu
  TECH_LEAD              // Responsable tècnic
  INTERN_SUPPORT         // Becaris / personal de suport
  GENERAL_MANAGER        // Direcció / encarregat general
}

enum ProjectStatus {
  PENDING_PREP           // Pendent de preparar (Rentman: option/quotation/draft)
  IN_PREPARATION         // En preparació (Rentman: confirmado)
  READY                  // Preparat (Rentman: preparado)
  OUT                    // Sortit (Rentman: en localización / retrasado / esperado de regreso)
  RETURNED               // Retornat (Rentman: retornado)
  CLOSED                 // Tancat (Rentman: closed)
}

enum IncidentStatus {
  INC_OPEN               // Oberta
  INC_IN_PROGRESS        // En investigació / reparació
  INC_WAITING_PARTS      // Esperant peces / recanvis
  INC_WAITING_CLIENT     // Esperant resposta client
  INC_RESOLVED           // Resolta
  INC_CLOSED             // Tancada
}

enum IncidentSeverity {
  LOW                    // No afecta sortides
  MEDIUM                 // Pot afectar sortides futures
  HIGH                   // Afecta una sortida propera
  CRITICAL               // Bloqueja una sortida imminent
}

enum OpTaskStatus {
  OP_PENDING
  OP_IN_PROGRESS
  OP_BLOCKED
  OP_DONE
  OP_CANCELLED
}

enum TaskCategory {
  WAREHOUSE      // Magatzem
  TECH           // Tècnica
  ADMIN          // Administració
  TRANSPORT      // Transport
  GENERAL        // General
}

enum TaskPriority {
  LOW            // Baixa
  NORMAL         // Normal
  HIGH           // Alta
  URGENT         // Urgent
}

enum ProjectType {
  DOCUMENTAL     // Documental
  INTERVIEW      // Entrevista
  EVENT          // Esdeveniment / Event
  ADVERTISING    // Publicitat
  CORPORATE      // Corporatiu
  MUSIC_VIDEO    // Videoclip
  FILM           // Pel·lícula / Curtmetratge
  TV             // Televisió
  PHOTO          // Fotografia
  OTHER          // Altres
}

enum TaskReminder {
  NONE           // Sense recordatori
  AT_TIME        // A l'hora de la tasca
  HOUR_BEFORE    // 1 hora abans
  DAY_BEFORE     // 1 dia abans
  CUSTOM         // Personalitzat
}

enum TaskRecurrence {
  NONE           // No es repeteix
  DAILY          // Cada dia
  WEEKLY         // Cada setmana
  MONTHLY        // Cada mes
  CUSTOM         // Personalitzada
}

enum PermissionLevel {
  NONE                   // Sense accés
  VIEW_ONLY              // Només veure
  OPERATE                // Veure + executar tasques
  MANAGE                 // Operar + assignar + validar
  FULL_ADMIN             // Tot, inclòs editar protocols i rols
}

// ===========================================
// Mòdul Protocol d'Empresa — Models
// ===========================================

model RoleDefinition {
  id              String          @id @default(cuid())
  code            OperationalRole @unique
  name            String                    // "Responsable principal de magatzem"
  shortName       String                    // "Mag. Principal"
  description     String?
  responsibilities Json                     // String[] de responsabilitats
  limitations     Json?                     // String[] de limitacions (becaris)
  sortOrder       Int             @default(0)
  isActive        Boolean         @default(true)
  color           String          @default("#2390A0")
  icon            String?                   // "warehouse", "wrench", "phone"
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relacions
  assignments     RoleAssignment[]
  permissions     RolePermission[]

  @@map("role_definitions")
}

model RoleAssignment {
  id              String          @id @default(cuid())
  roleId          String
  userId          String
  isPrimary       Boolean         @default(true)
  startDate       DateTime        @default(now())
  endDate         DateTime?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relacions
  role            RoleDefinition  @relation(fields: [roleId], references: [id])
  user            User            @relation(fields: [userId], references: [id])

  @@unique([roleId, userId, startDate])
  @@index([userId])
  @@index([roleId])
  @@map("role_assignments")
}

model RolePermission {
  id              String          @id @default(cuid())
  roleId          String
  section         String                    // "projects", "incidents", "protocols", "daily_plan", "roles", "equipment_blocking"
  level           PermissionLevel @default(VIEW_ONLY)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relacions
  role            RoleDefinition  @relation(fields: [roleId], references: [id])

  @@unique([roleId, section])
  @@map("role_permissions")
}

model RentalProject {
  id                  String         @id @default(cuid())
  name                String
  clientName          String?
  clientId            String?

  // Dates i horaris (cicle Rentman: check → rodatge → devolució)
  checkDate           DateTime?        // Planning day pre: tècnics preparen/recullen
  checkTime           String?
  departureDate       DateTime         // Shooting start: l'equip surt a rodar
  departureTime       String?
  shootEndDate        DateTime?        // Shooting end: fi del rodatge
  shootEndTime        String?
  returnDate          DateTime         // Planning day post: devolució material
  returnTime          String?
  actualReturnDate    DateTime?

  // Tipus i estat
  projectType         ProjectType?               // Tipus de projecte (per plantilles de tasques)
  status              ProjectStatus  @default(PENDING_PREP)
  priority            Int            @default(0) // 0=normal, 1=alta, 2=urgent

  // Responsables
  leadUserId          String?            // Responsable preparació
  techSupportUserId   String?            // Tècnic de suport assignat
  returnLeadUserId    String?            // Responsable devolució (pot ser diferent del de preparació)
  leadRoleCode        OperationalRole?

  // Transport
  transportType       String?        // "INTERN", "EXTERN", "CLIENT_PICKUP"
  transportNotes      String?
  pickupTime          String?

  // Validacions
  warehouseValidated  Boolean        @default(false)
  warehouseValidatedBy String?
  warehouseValidatedAt DateTime?
  techValidated       Boolean        @default(false)
  techValidatedBy     String?
  techValidatedAt     DateTime?
  techValidationRequired Boolean     @default(false)

  // Referències externes
  rentmanProjectId    String?
  rentmanStatus       String?          // Estat natiu de Rentman (confirmed, out, returned, etc.)
  budgetReference     String?

  // Observacions
  internalNotes       String?
  clientNotes         String?

  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  // Relacions
  client              Client?        @relation(fields: [clientId], references: [id])
  leadUser            User?          @relation("ProjectLead", fields: [leadUserId], references: [id])
  techSupportUser     User?          @relation("ProjectTechSupport", fields: [techSupportUserId], references: [id])
  returnLeadUser      User?          @relation("ProjectReturnLead", fields: [returnLeadUserId], references: [id])
  assignments         ProjectAssignment[]
  statusHistory       ProjectStatusChange[]
  incidents           Incident[]
  tasks               ProjectTask[]
  equipmentItems      ProjectEquipment[]
  communications      ProjectCommunication[]
  journalLines        JournalLine[]      @relation("JournalLineProject")

  @@index([departureDate])
  @@index([returnDate])
  @@index([status])
  @@index([leadUserId])
  @@index([priority])
  @@index([rentmanProjectId])
  @@map("rental_projects")
}

model ProjectAssignment {
  id              String          @id @default(cuid())
  projectId       String
  userId          String
  roleCode        OperationalRole
  isLead          Boolean         @default(false)
  notes           String?
  createdAt       DateTime        @default(now())

  // Relacions
  project         RentalProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id])

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_assignments")
}

model ProjectStatusChange {
  id              String         @id @default(cuid())
  projectId       String
  fromStatus      ProjectStatus?
  toStatus        ProjectStatus
  changedBy       String?
  reason          String?
  createdAt       DateTime       @default(now())

  // Relacions
  project         RentalProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
  @@map("project_status_changes")
}

model ProjectEquipment {
  id              String         @id @default(cuid())
  projectId       String
  equipmentId     String?
  itemName        String
  quantity        Int            @default(1)
  isCheckedOut    Boolean        @default(false)
  isReturned      Boolean        @default(false)
  returnCondition String?        // "OK", "DAMAGED", "MISSING", "CONSUMABLE_USED"
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relacions
  project         RentalProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  equipment       Equipment?     @relation(fields: [equipmentId], references: [id])

  @@index([projectId])
  @@index([equipmentId])
  @@map("project_equipment")
}

model ProjectTask {
  id              String         @id @default(cuid())
  projectId       String?        // Opcional: tasca pot ser independent d'un projecte
  title           String
  description     String?
  notes           String?        // Notes addicionals

  // Responsables
  createdById     String?
  assignedToId    String?
  completedById   String?

  // Estat, categoria i prioritat
  status          OpTaskStatus   @default(OP_PENDING)
  category        TaskCategory   @default(GENERAL)
  priority        TaskPriority   @default(NORMAL)

  // Plantilla d'origen (si va ser creada des d'una plantilla)
  templateId      String?

  // Data i hora (tot opcional)
  dueAt           DateTime?      // Data límit
  dueTime         String?        // Hora (HH:MM), opcional
  completedAt     DateTime?

  // Recordatori
  reminder        TaskReminder   @default(NONE)
  reminderCustom  String?        // Per recordatori personalitzat (ex: "30m", "2h")

  // Repetició
  recurrence      TaskRecurrence @default(NONE)
  recurrenceCustom String?       // Per repetició personalitzada (ex: "cada 2 setmanes")
  recurrenceEndAt DateTime?      // Fi de la repetició

  // Legacy
  requiresSupervision Boolean   @default(false)

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relacions
  project         RentalProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template        TaskTemplate?  @relation(fields: [templateId], references: [id])
  createdBy       User?          @relation("TaskCreator", fields: [createdById], references: [id])
  assignedTo      User?          @relation("TaskAssignee", fields: [assignedToId], references: [id])
  completedBy     User?          @relation("TaskCompleter", fields: [completedById], references: [id])
  checklistItems  TaskChecklistItem[]
  comments        TaskComment[]
  activities      TaskActivity[]

  @@index([projectId])
  @@index([assignedToId])
  @@index([createdById])
  @@index([status])
  @@index([dueAt])
  @@index([category])
  @@index([priority])
  @@map("project_tasks")
}

// ===========================================
// Subtasques / Checklist dins tasques
// ===========================================

model TaskChecklistItem {
  id              String         @id @default(cuid())
  taskId          String
  title           String
  isCompleted     Boolean        @default(false)
  completedById   String?
  completedAt     DateTime?
  sortOrder       Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relacions
  task            ProjectTask    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  completedBy     User?          @relation("ChecklistCompleter", fields: [completedById], references: [id])

  @@index([taskId])
  @@map("task_checklist_items")
}

// ===========================================
// Plantilles de tasques
// ===========================================

model TaskTemplate {
  id              String         @id @default(cuid())
  name            String                       // "Preparació sortida documental"
  description     String?
  projectType     ProjectType?                 // Tipus de projecte vinculat (opcional)
  category        TaskCategory   @default(GENERAL)
  isDefault       Boolean        @default(false)  // S'aplica automàticament
  isActive        Boolean        @default(true)
  sortOrder       Int            @default(0)
  createdById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relacions
  createdBy       User?          @relation("TemplateCreator", fields: [createdById], references: [id])
  items           TaskTemplateItem[]
  tasks           ProjectTask[]                // Tasques creades des d'aquesta plantilla

  @@index([projectType])
  @@index([isDefault])
  @@map("task_templates")
}

model TaskTemplateItem {
  id              String         @id @default(cuid())
  templateId      String
  title           String                       // Títol de la tasca a crear
  description     String?
  category        TaskCategory   @default(GENERAL)
  priority        TaskPriority   @default(NORMAL)
  daysOffset      Int            @default(0)   // Dies relatiu a data sortida (-2 = 2 dies abans)
  sortOrder       Int            @default(0)
  assignToRole    String?                      // Rol que hauria de fer la tasca (optatiu)

  // Checklist items predefinits (JSON array de strings)
  checklistItems  Json?                        // ["Comprovar bateries", "Verificar targetes", ...]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relacions
  template        TaskTemplate   @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("task_template_items")
}

// ===========================================
// Comentaris i activitat de tasques
// ===========================================

model TaskComment {
  id              String         @id @default(cuid())
  taskId          String
  userId          String
  content         String                       // Text del comentari
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Relacions
  task            ProjectTask    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user            User           @relation("TaskCommenter", fields: [userId], references: [id])

  @@index([taskId])
  @@map("task_comments")
}

model TaskActivity {
  id              String         @id @default(cuid())
  taskId          String
  userId          String?                      // null si és automàtic del sistema
  action          String                       // "status_change", "assigned", "comment", "checklist_done", etc.
  details         Json?                        // { from: "OP_PENDING", to: "OP_IN_PROGRESS" }
  createdAt       DateTime       @default(now())

  // Relacions
  task            ProjectTask    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user            User?          @relation("TaskActivityUser", fields: [userId], references: [id])

  @@index([taskId])
  @@index([createdAt])
  @@map("task_activities")
}

model Incident {
  id              String           @id @default(cuid())
  projectId       String?
  equipmentId     String?

  title           String
  description     String
  severity        IncidentSeverity @default(MEDIUM)
  status          IncidentStatus   @default(INC_OPEN)

  reportedById    String
  assignedToId    String?
  assignedRoleCode OperationalRole?

  affectsFutureDeparture Boolean  @default(false)
  affectedProjectId      String?
  requiresClientNotification Boolean @default(false)
  clientNotified  Boolean        @default(false)
  equipmentBlocked Boolean       @default(false)

  actionTaken     String?
  resolvedAt      DateTime?
  resolvedById    String?
  resolutionNotes String?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relacions
  project         RentalProject?   @relation(fields: [projectId], references: [id])
  equipment       Equipment?       @relation(fields: [equipmentId], references: [id])

  @@index([projectId])
  @@index([equipmentId])
  @@index([status])
  @@index([severity])
  @@index([reportedById])
  @@map("incidents")
}

model DailyPlan {
  id              String         @id @default(cuid())
  date            DateTime       @unique
  summary         String?
  availableStaff  Json?
  urgentNotes     String?
  createdById     String?
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([date])
  @@map("daily_plans")
}

model ProjectCommunication {
  id              String         @id @default(cuid())
  projectId       String
  authorId        String
  targetRoleCode  OperationalRole?
  message         String
  isUrgent        Boolean        @default(false)
  isRead          Boolean        @default(false)
  readAt          DateTime?
  createdAt       DateTime       @default(now())

  // Relacions
  project         RentalProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([targetRoleCode])
  @@index([isRead])
  @@map("project_communications")
}

model Protocol {
  id              String         @id @default(cuid())
  title           String
  slug            String         @unique
  category        String         // "daily", "departure", "return", "incident", "maintenance"
  content         String
  sortOrder       Int            @default(0)
  isActive        Boolean        @default(true)
  lastEditedById  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([category])
  @@map("protocols")
}

// ===========================================
// Regles de l'agent comptable
// ===========================================

enum AgentRuleCategory {
  INVOICES        // Factures (duplicats, validació, etc.)
  CLASSIFICATION  // Classificació comptable (PGC)
  CONCILIATION    // Conciliació bancària
  SUPPLIERS       // Proveïdors
  ANOMALIES       // Detecció d'anomalies
  FISCAL          // IVA, impostos, fiscal
  GENERAL         // Regles generals
}

enum AgentRuleSource {
  MANUAL          // Creada manualment per l'usuari
  LEARNED         // Apresa d'una correcció de l'usuari
  SYSTEM          // Regla del sistema predefinida
}

model AgentRule {
  id              String            @id @default(cuid())
  title           String            // Títol curt descriptiu
  condition       String            // Condició: "Quan passa X..."
  action          String            // Acció: "Fer Y..."
  category        AgentRuleCategory @default(GENERAL)
  source          AgentRuleSource   @default(MANUAL)
  priority        Int               @default(0) // 0=normal, 1=alta, 2=crítica
  isActive        Boolean           @default(true)
  examples        String?           // Exemples concrets (text lliure)
  createdById     String?
  createdBy       User?             @relation("agentRulesCreated", fields: [createdById], references: [id])
  timesApplied    Int               @default(0) // Quantes vegades s'ha usat
  lastAppliedAt   DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([category])
  @@index([isActive])
  @@map("agent_rules")
}

// ===========================================
// Jobs automàtics de l'agent
// ===========================================

model AgentJob {
  id              String    @id @default(cuid())
  jobType         String    // "classify", "anomalies", "duplicates", "overdue", "conciliation"
  status          String    @default("running") // "running", "completed", "failed"
  itemsProcessed  Int       @default(0)
  itemsCreated    Int       @default(0) // suggeriments creats
  summary         String?   // Resum breu del que ha fet
  details         Json?     // Detalls complets (llista de factures processades, etc.)
  error           String?   // Error si ha fallat
  durationMs      Int?      // Temps d'execució en ms
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  createdAt       DateTime  @default(now())

  @@index([jobType])
  @@index([createdAt])
  @@map("agent_jobs")
}

// Configuració de quins jobs estan actius
model AgentJobConfig {
  id              String    @id @default(cuid())
  jobType         String    @unique // "classify", "anomalies", etc.
  label           String    // Nom llegible
  description     String?   // Descripció del que fa
  isEnabled       Boolean   @default(true)
  cronSchedule    String    @default("0 */2 * * *") // Per defecte cada 2 hores
  lastRunAt       DateTime?
  updatedAt       DateTime  @updatedAt

  @@map("agent_job_configs")
}

model OpNotification {
  id              String         @id @default(cuid())
  userId          String
  type            String         // "project_created", "incident_critical", etc.
  title           String
  message         String
  entityType      String?        // "rental_project", "incident"
  entityId        String?
  priority        String         @default("normal") // "low", "normal", "high", "urgent"
  isRead          Boolean        @default(false)
  readAt          DateTime?
  createdAt       DateTime       @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("op_notifications")
}

// ===========================================
// Lectures de consum elèctric (Shelly Pro 3EM)
// ===========================================

model ShellyEnergyReading {
  id            String   @id @default(cuid())
  date          DateTime @db.Date          // Dia de la lectura (1 fila per dia)

  // Energia per fase en kWh
  whPhaseA      Decimal  @db.Decimal(12, 4) @default(0)
  whPhaseB      Decimal  @db.Decimal(12, 4) @default(0)
  whPhaseC      Decimal  @db.Decimal(12, 4) @default(0)
  totalKwh      Decimal  @db.Decimal(12, 4) @default(0) // Suma de les 3 fases

  // Metadades
  minuteRecords Int      @default(0)       // Nombre de registres d'1 minut sumats (ideal: 1440)
  deviceId      String?                     // ID del dispositiu Shelly

  syncedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([date, deviceId])
  @@index([date])
  @@map("shelly_energy_readings")
}

// ===========================================
// Absències de personal
// ===========================================

enum AbsenceType {
  VACANCES
  MALALTIA
  RODATGE
  TRANSPORT
  PERMIS
  FORMACIO
  ALTRE
}

enum AbsenceStatus {
  PENDENT
  APROVADA
  REBUTJADA
}

model StaffAbsence {
  id            String        @id @default(cuid())
  userId        String
  approvedById  String?
  startDate     DateTime      @db.Date
  endDate       DateTime      @db.Date
  type          AbsenceType
  status        AbsenceStatus @default(PENDENT)
  isPartial     Boolean       @default(false)  // Absència parcial (només unes hores)
  startTime     String?       // HH:MM — hora inici absència (si parcial)
  endTime       String?       // HH:MM — hora fi absència (si parcial)
  transportId   String?       // Referència al transport que ha generat l'absència
  notes         String?
  rejectReason  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User          @relation("AbsenceUser", fields: [userId], references: [id])
  approvedBy    User?         @relation("AbsenceApprover", fields: [approvedById], references: [id])

  @@index([userId])
  @@index([startDate, endDate])
  @@index([status])
  @@index([transportId])
  @@map("staff_absences")
}

// ===========================================
// Control Horari
// ===========================================

enum TimeEntryType {
  OFICINA
  RODATGE
  TRANSPORT_ENTREGA
  TRANSPORT_RECOLLIDA
  TRANSPORT_COMPLET
}

enum ShootingRole {
  VIDEOASSIST
  AUX_CAMERA
}

enum OvertimeStatus {
  PENDENT
  APROVADA
  REBUTJADA
}

model TimeEntry {
  id              String          @id @default(cuid())
  userId          String
  date            DateTime        @db.Date
  clockIn         DateTime
  clockOut        DateTime?
  type            TimeEntryType   @default(OFICINA)
  shootingRole    ShootingRole?   // Només si type = RODATGE
  projectName     String?         // Nom del projecte/rodatge/transport
  notes           String?
  // Hores extres (calculades automàticament, jornada estàndard 8h)
  totalMinutes    Int?            // Minuts totals treballats
  overtimeMinutes Int             @default(0)
  overtimeStatus  OvertimeStatus  @default(PENDENT)
  approvedById    String?
  approvedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user            User            @relation("TimeEntryUser", fields: [userId], references: [id])
  approvedBy      User?           @relation("TimeEntryApprover", fields: [approvedById], references: [id])

  @@index([userId])
  @@index([date])
  @@index([userId, date])
  @@index([overtimeStatus])
  @@map("time_entries")
}

// ===========================================
// Subscripcions Push (PWA)
// ===========================================

model PushSubscription {
  id          String   @id @default(cuid())
  userId      String
  endpoint    String   @unique
  p256dh      String
  auth        String
  userAgent   String?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ===========================================
// Logística — Transports
// ===========================================

model EmpresaLogistica {
  id              String   @id @default(cuid())
  nom             String   @unique
  emailContacte   String?
  telefonContacte String?
  nomContacte     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  conductors      Conductor[]
  transports      Transport[]

  @@map("empreses_logistica")
}

model Conductor {
  id          String   @id @default(cuid())
  nom         String
  telefon     String?
  empresaId   String?
  userId      String?  @unique  // Vinculat a un usuari Seito (absències automàtiques)
  createdAt   DateTime @default(now())

  empresa     EmpresaLogistica? @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  user        User?             @relation("ConductorUser", fields: [userId], references: [id], onDelete: SetNull)
  transports  Transport[]

  @@map("conductors")
}

model Transport {
  id                   String    @id @default(cuid())
  projecte             String?
  tipusServei          String    @default("Entrega")
  origen               String?
  notesOrigen          String?
  desti                String?
  notesDesti           String?
  dataCarrega          DateTime? @db.Date
  dataEntrega          DateTime? @db.Date
  horaRecollida        String?
  horaEntregaEstimada  String?
  horaFiPrevista       String?
  horaIniciReal        String?
  horaFiReal           String?
  minutsExtres         Int?
  responsableProduccio String?
  telefonResponsable   String?
  conductorId          String?
  empresaId            String?
  estat                String    @default("Pendent")
  motiuCancellacio     String?
  cancellatAt          DateTime?
  notes                String?
  publicToken          String?   @unique @default(cuid())
  historial            Json      @default("[]")
  createdById          String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  conductor            Conductor?         @relation(fields: [conductorId], references: [id], onDelete: SetNull)
  empresa              EmpresaLogistica?  @relation(fields: [empresaId], references: [id], onDelete: SetNull)
  createdBy            User?              @relation("transportCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([estat])
  @@index([dataCarrega])
  @@index([conductorId])
  @@index([empresaId])
  @@map("transports")
}

// ===========================================
// Comptabilitat formal (Sprint 1 — Fonaments)
// ===========================================

enum AccountType {
  ASSET           // Actiu (grups 1, 2, 3, 4 deutor, 5 deutor)
  LIABILITY       // Passiu (grups 1, 4 creditor, 5 creditor)
  EQUITY          // Patrimoni net (grup 1, 12)
  INCOME          // Ingressos (grup 7)
  EXPENSE         // Despeses (grup 6)
}

enum FiscalYearStatus {
  OPEN            // Es poden crear/editar assentaments
  CLOSING         // En procés de tancament (regularització)
  CLOSED          // Tancat, només lectura
}

model Company {
  id                   String    @id @default(cuid())
  legalName            String
  commercialName       String?
  nif                  String    @unique
  address              String?
  postalCode           String?
  city                 String?
  province             String?
  country              String    @default("ES")
  phone                String?
  email                String?
  website              String?

  // Configuració comptable
  fiscalYearStartMonth Int       @default(1)
  defaultCurrency      String    @default("EUR")
  defaultVatRate       Decimal   @default(21) @db.Decimal(5, 2)
  defaultIrpfRate      Decimal   @default(15) @db.Decimal(5, 2)
  corporateTaxRate     Decimal   @default(25) @db.Decimal(5, 2)

  // Configuració AEAT
  aeatRegime           String    @default("GENERAL")
  is347Threshold       Decimal   @default(3005.06) @db.Decimal(12, 2)
  vatPeriod            String    @default("QUARTERLY")

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relacions
  fiscalYears          FiscalYear[]
  chartOfAccounts      ChartOfAccount[]
  journalEntries       JournalEntry[]
  receivedInvoices     ReceivedInvoice[]
  issuedInvoices       IssuedInvoice[]
  bankMovements        BankMovement[]

  @@map("companies")
}

model FiscalYear {
  id              String           @id @default(cuid())
  companyId       String
  year            Int
  startDate       DateTime
  endDate         DateTime
  status          FiscalYearStatus @default(OPEN)
  locked          Boolean          @default(false)
  lockedAt        DateTime?
  lockedById      String?

  // Resultats del tancament (omplerts en CLOSED)
  totalRevenue    Decimal?         @db.Decimal(14, 2)
  totalExpenses   Decimal?         @db.Decimal(14, 2)
  netResult       Decimal?         @db.Decimal(14, 2)
  corporateTax    Decimal?         @db.Decimal(14, 2)

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relacions
  company         Company          @relation(fields: [companyId], references: [id])
  lockedBy        User?            @relation("fiscalYearLocked", fields: [lockedById], references: [id])
  journalEntries  JournalEntry[]

  @@unique([companyId, year])
  @@index([status])
  @@map("fiscal_years")
}

model ChartOfAccount {
  id              String           @id @default(cuid())
  companyId       String
  code            String                                 // "629000", "430001"
  name            String
  description     String?

  // Jerarquia
  parentId        String?
  level           Int              @default(0)           // 0=grup, 1=subgrup, 2=compte, 3=subcompte
  isLeaf          Boolean          @default(true)        // Si es pot usar a apunts

  // Classificació
  type            AccountType
  subtype         String?                                // "CURRENT_ASSET", "FIXED_ASSET", "VAT_INPUT", etc.

  // Configuració
  isActive        Boolean          @default(true)
  isSystem        Boolean          @default(false)       // Compte del sistema (no editable)
  defaultVatRate  Decimal?         @db.Decimal(5, 2)
  taxBookType     String?                                // "VAT_INPUT", "VAT_OUTPUT", "IRPF"

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Relacions
  company         Company          @relation(fields: [companyId], references: [id])
  parent          ChartOfAccount?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children        ChartOfAccount[] @relation("AccountHierarchy")
  journalLines    JournalLine[]
  receivedInvoicesAsAccount       ReceivedInvoice[]   @relation("ReceivedInvoiceAccount")
  receivedInvoicesAsCounterparty  ReceivedInvoice[]   @relation("ReceivedInvoiceCounterparty")
  issuedInvoicesAsAccount         IssuedInvoice[]     @relation("IssuedInvoiceAccount")
  issuedInvoicesAsCounterparty    IssuedInvoice[]     @relation("IssuedInvoiceCounterparty")
  suppliersDefaultExpense         Supplier[]          @relation("SupplierDefaultExpense")
  suppliersCounterparty           Supplier[]          @relation("SupplierCounterparty")
  clientsDefaultRevenue           Client[]            @relation("ClientDefaultRevenue")
  clientsCounterparty             Client[]            @relation("ClientCounterparty")
  bankAccounts                    BankAccount[]       @relation("BankAccountAccount")
  bankMovements                   BankMovement[]      @relation("BankMovementAccount")

  @@unique([companyId, code])
  @@index([type])
  @@index([parentId])
  @@map("chart_of_accounts")
}

model AuditLog {
  id              String    @id @default(cuid())
  companyId       String?

  // Què ha passat
  entityType      String                                 // "JournalEntry", "ReceivedInvoice", etc.
  entityId        String
  action          String                                 // "CREATE", "UPDATE", "DELETE", "POST", "REVERSE", "LOCK"

  // Diferències (snapshot abans/després)
  beforeData      Json?
  afterData       Json?
  changedFields   String[]  @default([])

  // Qui i quan
  userId          String
  userEmail       String?                                // Snapshot per si l'usuari es desactiva
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime  @default(now())

  // Relacions
  user            User      @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ===========================================
// Llibre Diari (Sprint 2)
// ===========================================

enum JournalEntryType {
  RECEIVED_INVOICE
  ISSUED_INVOICE
  PAYMENT
  COLLECTION
  BANK_TRANSFER
  BANK_FEE
  AMORTIZATION
  PAYROLL
  TAX_PAYMENT
  TAX_ACCRUAL
  YEAR_CLOSING
  YEAR_OPENING
  ADJUSTMENT
  OTHER
}

enum JournalEntrySource {
  MANUAL
  AUTO_INVOICE
  AUTO_BANK
  AUTO_AMORTIZATION
  AUTO_CLOSING
  AGENT
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  REVERSED
}

model JournalEntry {
  id              String              @id @default(cuid())
  companyId       String
  fiscalYearId    String
  entryNumber     Int                                          // Correlatiu dins de l'exercici

  date            DateTime
  description     String

  type            JournalEntryType    @default(OTHER)
  source          JournalEntrySource  @default(MANUAL)
  sourceRef       String?                                      // Polimòrfic — fins que afegim FK explícites a sprints futurs

  status          JournalEntryStatus  @default(DRAFT)
  reversedById    String?                                      // Si REVERSED: FK a l'assentament d'inversió que el corregeix
  reversesId      String?                                      // Si és correu d'inversió: FK al que anul·la

  createdById     String
  createdAt       DateTime            @default(now())
  postedById      String?
  postedAt        DateTime?
  updatedAt       DateTime            @updatedAt

  // Relacions
  company         Company             @relation(fields: [companyId], references: [id])
  fiscalYear      FiscalYear          @relation(fields: [fiscalYearId], references: [id])
  createdBy       User                @relation("journalCreated", fields: [createdById], references: [id])
  postedBy        User?               @relation("journalPosted", fields: [postedById], references: [id])
  reversedBy      JournalEntry?       @relation("JournalEntryReversal", fields: [reversedById], references: [id])
  reverses        JournalEntry?       @relation("JournalEntryReverses", fields: [reversesId], references: [id])
  reversalOf      JournalEntry[]      @relation("JournalEntryReversal")
  reversedBys     JournalEntry[]      @relation("JournalEntryReverses")
  lines           JournalLine[]
  receivedInvoice ReceivedInvoice?    @relation("ReceivedInvoiceJournal")
  issuedInvoice   IssuedInvoice?      @relation("IssuedInvoiceJournal")
  bankMovement    BankMovement?       @relation("BankMovementJournal")

  @@unique([companyId, fiscalYearId, entryNumber])
  @@index([date])
  @@index([type])
  @@index([status])
  @@index([fiscalYearId, date])
  @@index([sourceRef])
  @@map("journal_entries")
}

model JournalLine {
  id                String          @id @default(cuid())
  journalEntryId    String
  accountId         String

  debit             Decimal         @default(0) @db.Decimal(14, 2)
  credit            Decimal         @default(0) @db.Decimal(14, 2)

  description       String?
  counterpartyId    String?                                   // FK lliure a Supplier o Client (sense relació explícita per polimorfisme)
  counterpartyType  String?                                   // "SUPPLIER" o "CLIENT"

  projectId         String?                                   // Analítica per projecte (camp present, UI post-MVP)

  // Camps fiscals (per al càlcul del 303/390 sense haver de recórrer a la factura)
  vatRate           Decimal?        @db.Decimal(5, 2)
  vatBase           Decimal?        @db.Decimal(14, 2)
  irpfRate          Decimal?        @db.Decimal(5, 2)
  irpfBase          Decimal?        @db.Decimal(14, 2)

  sortOrder         Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  // Relacions
  journalEntry      JournalEntry    @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account           ChartOfAccount  @relation(fields: [accountId], references: [id])
  project           RentalProject?  @relation("JournalLineProject", fields: [projectId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
  @@index([projectId])
  @@map("journal_lines")
}
