# Copy to .env and fill in values. Never commit .env.

# --- LLM provider ---
# "ollama" → free, local, slower (development default)
# "anthropic" → paid Claude API (production / when local quality insufficient)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434

# --- API keys ---
# Required only when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Web search providers (used by tools regardless of LLM provider)
EXA_API_KEY=
BRAVE_SEARCH_API_KEY=

# --- Database ---
DATABASE_URL=postgresql+psycopg://seito:pass@localhost:5432/marketing

# --- Models per agent ---
# Examples for Ollama: qwen3:14b, qwen3:32b, llama3.3:70b, deepseek-r1:32b, qwen2.5-coder:32b
# Examples for Anthropic: claude-sonnet-4-6, claude-opus-4-7, claude-haiku-4-5-20251001
MODEL_MANAGER=qwen3:14b
MODEL_INVESTIGATOR=qwen3:14b
MODEL_STRATEGIST=qwen3:14b
MODEL_LEAD_HUNTER=qwen3:14b
MODEL_FACT_CHECKER=qwen3:14b

# --- Budgets (hard caps per run; only meaningful when paying per token) ---
MAX_USD_PER_RUN=3.00
MAX_TOKENS_PER_RUN=400000
MAX_TOOL_CALLS_PER_RUN=150

# --- Feature flags ---
AUTONOMOUS_MODE=false
ENABLE_SCRAPING=true
SCRAPING_RPS_PER_DOMAIN=0.5
SCRAPER_USER_AGENT=SeitoMarketingBot/0.1 (+https://seitocamera.com/bot)

# --- Observability ---
LOG_LEVEL=INFO
LOG_DIR=./logs

# --- SeitoCamera Admin (Node backend) integration ---
# El admin_client.py crida el backend per llegir context d'empresa unificat.
# Ha de coincidir amb SERVICE_API_KEY del backend Node (./.env, no aquest).
ADMIN_API_BASE_URL=http://localhost:4000
SERVICE_API_KEY=
# (alias obsolet, només per compat amb instal·lacions antigues — usa SERVICE_API_KEY)
# ADMIN_SERVICE_KEY=
