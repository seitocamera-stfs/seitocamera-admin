# ===========================================
# SeitoCamera Admin — Variables de Producció
# ===========================================
# Copia aquest fitxer a .env i CANVIA tots els valors!
# ===========================================

# Domini
DOMAIN=admin.seito.camera
FRONTEND_URL=https://admin.seito.camera

# Base de dades — USA PASSWORDS FORTS!
DB_USER=seitocamera
DB_PASSWORD=CANVIA_AIXO_password_molt_llarg_i_aleatori_2024
DB_NAME=seitocamera_admin

# Redis
REDIS_PASSWORD=CANVIA_AIXO_un_altre_password_fort

# JWT — Genera amb: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CANVIA_AIXO_genera_amb_crypto
JWT_REFRESH_SECRET=CANVIA_AIXO_diferent_del_anterior

# Certbot / Let's Encrypt
CERTBOT_EMAIL=seitocamera@gmail.com

# Google Maps — càlcul automàtic de km per transports fora de Barcelona
# Necessita Distance Matrix API habilitada al projecte de Google Cloud.
GOOGLE_MAPS_API_KEY=
# Adreça d'origen per defecte si Company.address no està definida (override env opcional)
LOGISTICS_HQ_ADDRESS=Barcelona, España

# Service-key per a crides internes (marketing/Python → backend Node).
# El mateix valor s'ha de definir al .env del subprojecte marketing/ amb el
# mateix nom (SERVICE_API_KEY). Genera amb:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SERVICE_API_KEY=

# Marketing AI feature flag.
# false → bloca POST /marketing/runs (servidor no té Ollama, els runs petarien)
#         + amaga els links del Sidebar.
# true  → activa el mòdul (només posar a true en entorns amb Ollama disponible).
#
# Mac local: posa a true. Producció: deixa a false i importa leads via
# POST /api/marketing/import-external-leads (no està gated per la flag, és el
# bridge Mac→Servidor):
#
#   curl -X POST https://admin.seito.camera/api/marketing/import-external-leads \
#     -H "Authorization: Bearer <JWT>" \
#     -H "Content-Type: application/json" \
#     -d @marketing/out/leads_20260505_120000.json
MARKETING_ENABLED=false

# Cap mensual de cost del marketing IA (USD). Default 25.
# Només té efecte si MARKETING_ENABLED=true.
MARKETING_MAX_USD_PER_MONTH=25
# Cap pessimista per run (USD). Default 3. Usat per a la projecció pre-llançament.
MAX_USD_PER_RUN=3

# Gemini 2.0 Flash per extracció multimodal de factures.
# Generar a https://aistudio.google.com/apikey (free tier suficient per ús normal:
# 15 RPM, 1500 req/dia, 1M tokens/min). Multimodal — passa el PDF directament,
# ~50× més barat que Claude i molt millor amb estructures complexes.
# Si no es defineix, el sistema cau al fallback de Claude.
GEMINI_API_KEY=
